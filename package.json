{
  "name": "bizsaathi",
  "version": "0.3.0",
  "private": true,
  "description": "Role-based AI operations workspace for MSMEs and agencies, designed to work with Paperclip, Ollama, and governed human approvals.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3080",
    "build": "next build",
    "start": "next start -p ${PORT:-8080}",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose up --build",
    "dokploy:check": "node -e \"fetch('http://127.0.0.1:8080/api/health').then(r=>console.log(r.status)).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "clsx": "2.1.1",
    "jose": "6.2.3",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "prisma": "7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
